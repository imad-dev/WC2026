{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-matches",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/sync-streams",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/sync-standings-scorers",
      "schedule": "0 2 * * *"
    }
  ]
}
